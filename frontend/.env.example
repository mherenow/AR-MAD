# API Configuration
# Base URL for backend API requests
# Leave empty (or unset) during development to use Vite proxy
# Set for production builds when frontend is served from different origin
VITE_API_BASE_URL=

# Examples:
# Development (default, uses proxy): VITE_API_BASE_URL=
# Production: VITE_API_BASE_URL=https://api.example.com
# Local testing: VITE_API_BASE_URL=http://localhost:8000
